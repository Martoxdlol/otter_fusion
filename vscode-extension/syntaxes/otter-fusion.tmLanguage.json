{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Otter Fusion",
  "scopeName": "source.of",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#chars" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#types" },
    { "include": "#function-decl" },
    { "include": "#function-call" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.of",
          "match": "//.*$"
        },
        {
          "name": "comment.block.of",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.of",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.of",
          "match": "\\\\."
        }
      ]
    },
    "chars": {
      "name": "string.quoted.single.of",
      "match": "'(\\\\.|[^\\\\'])'"
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.of",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.of",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.of",
          "match": "\\b(if|else|for|while|return|match|continue|break|in|is)\\b"
        },
        {
          "name": "storage.type.of",
          "match": "\\b(function|struct|interface|class|extend|type|extern|var)\\b"
        },
        {
          "name": "keyword.operator.cast.of",
          "match": "\\b(as)\\b"
        },
        {
          "name": "variable.language.self.of",
          "match": "\\bself\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.of",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.of",
          "match": "\\bnull\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.of",
          "match": "\\b(i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|bool|str|char|void)\\b"
        },
        {
          "name": "entity.name.type.of",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "function-decl": {
      "match": "\\b(function)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "storage.type.of" },
        "2": { "name": "entity.name.function.of" }
      }
    },
    "function-call": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.of" }
      }
    },
    "operators": {
      "name": "keyword.operator.of",
      "match": "==|!=|=>|&&|\\|\\||[+\\-*/%<>=!|]"
    },
    "punctuation": {
      "patterns": [
        { "name": "punctuation.terminator.of", "match": ";" },
        { "name": "punctuation.separator.of", "match": "[,:.]" }
      ]
    }
  }
}
